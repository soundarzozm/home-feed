# The port the express server will listen on
FEEDGEN_PORT=3000

# The hostname/domain where your feed generator will be deployed (must support HTTPS)
# Do not include protocol (http:// or https://), e.g. "my-feed.onrender.com" or "feed.mydomain.com"
FEEDGEN_HOSTNAME="your-feed-domain.com"

# The DID of your personal Bluesky account that will own/publish this feed
FEEDGEN_PUBLISHER_DID="did:plc:xxxxxxxxxxxxxxxxxxxxxxxx"

# SQLite database file location
FEEDGEN_SQLITE_LOCATION="./feed.db"

# Bluesky credentials for the publishing script
BSKY_HANDLE="your-handle.bsky.social"

# App password generated via Bluesky Settings > App Passwords
BSKY_PASSWORD="xxxx-xxxx-xxxx-xxxx"
